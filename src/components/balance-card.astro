---
---

<div class="bc-stage">
  <div
    class="balance-card"
    aria-label="Chumz user growth: from 30,000 users in January 2023 to over 500,000 today"
  >
    <div class="bc-top">
      <span class="bc-label">Users served</span>
      <span class="bc-chip" aria-hidden="true"></span>
    </div>
    <div class="bc-amount"><span id="counter">30,000</span><small>+</small></div>
    <p class="bc-caption">Chumz · Jan 2023 → today · smallest deposit: $0.05</p>
    <div class="bc-foot">
      <span>Growth<br /><b>16.7×</b></span>
      <span>Platform<br /><b>iOS · Android</b></span>
      <span>Rails<br /><b>Mobile money</b></span>
    </div>
  </div>
</div>

<style>
  .bc-stage {
    width: 100%;
    max-width: 460px;
    perspective: 1000px;
    animation: bc-float 6s ease-in-out infinite;
  }
  @keyframes bc-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-9px);
    }
  }
  .balance-card {
    background: linear-gradient(
      150deg,
      var(--color-surface-highlight) 0%,
      var(--color-surface-elevated) 55%,
      var(--color-surface-shadow) 100%
    );
    border: 1px solid rgba(255, 180, 84, 0.25);
    color: var(--color-text);
    border-radius: 22px;
    padding: 26px 32px;
    box-shadow:
      0 18px 34px -14px rgba(0, 0, 0, 0.6),
      0 46px 100px -32px rgba(0, 0, 0, 0.85);
    position: relative;
    overflow: hidden;
    transform: rotate(1deg);
    transition: transform 150ms ease-out;
  }
  .balance-card::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(600px 240px at 110% -10%, rgba(255, 180, 84, 0.16), transparent 60%);
  }
  .bc-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }
  .bc-label {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .bc-chip {
    width: 38px;
    height: 28px;
    border-radius: 6px;
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-accent-dark));
  }
  .bc-amount {
    font-weight: 800;
    font-size: clamp(38px, 4.4vw, 52px);
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    color: var(--color-accent);
  }
  .bc-amount small {
    font-size: 0.42em;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }
  #counter {
    background-image: linear-gradient(
      100deg,
      var(--color-accent) 0%,
      var(--color-accent) 32%,
      var(--color-accent-light) 44%,
      var(--color-text) 50%,
      var(--color-accent-light) 56%,
      var(--color-accent) 68%,
      var(--color-accent) 100%
    );
    background-size: 300% 100%;
    background-position: 0% 0;
    background-repeat: no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  #counter.bc-shine-active {
    animation: bc-shine 2.6s ease-in-out;
  }
  @keyframes bc-shine {
    from {
      background-position: 100% 0;
    }
    to {
      background-position: 0% 0;
    }
  }
  .bc-caption {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--color-text-muted);
    margin-top: 12px;
  }
  .bc-foot {
    display: flex;
    justify-content: space-between;
    margin-top: 22px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--color-text-muted);
  }
  .bc-foot span b {
    display: block;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
  }

  @media (max-width: 940px) {
    .bc-stage {
      max-width: 440px;
      margin: 0 auto;
    }
    .balance-card {
      transform: none;
    }
  }
</style>

<script>
  const el = document.getElementById('counter');
  if (el) {
    const target = 500000;
    const start = 30000;
    const dur = 2400;

    const scheduleShine = () => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const sweep = () => {
        el.classList.remove('bc-shine-active');
        void el.offsetWidth;
        el.classList.add('bc-shine-active');
      };
      setTimeout(() => {
        sweep();
        setInterval(sweep, 5000);
      }, 600);
    };

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = target.toLocaleString();
      scheduleShine();
    } else {
      let t0: number | null = null;
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      const step = (ts: number) => {
        if (t0 === null) t0 = ts;
        const p = Math.min((ts - t0) / dur, 1);
        el.textContent = Math.round(start + (target - start) * ease(p)).toLocaleString();
        if (p < 1) {
          requestAnimationFrame(step);
        } else {
          scheduleShine();
        }
      };
      requestAnimationFrame(step);
    }
  }
</script>

<script>
  const card = document.querySelector<HTMLElement>('.balance-card');
  if (
    card &&
    window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
    !window.matchMedia('(prefers-reduced-motion: reduce)').matches
  ) {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const px = (e.clientX - rect.left) / rect.width;
      const py = (e.clientY - rect.top) / rect.height;
      const rotateY = (px - 0.5) * 14;
      const rotateX = (0.5 - py) * 14;
      card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'rotateX(0deg) rotateY(0deg)';
    });
  }
</script>
