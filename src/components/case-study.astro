---
import CaseStudyStep from "./case-study-step.astro";
import PhoneMockup from "./phone-mockup.astro";
---

<section class="case" id="case">
  <div class="wrap">
    <div class="case-head">
      <p class="chapter">Case study № 1</p>
      <h2>Chumz: engineering trust into micro-savings</h2>
      <p>
        When your users are trusting an app with their savings — sometimes KES 5
        (0.05$) at a time — every janky screen is a reason to leave. My job:
        make the mobile experience feel worthy of that trust. Scroll through the
        story; the phone follows along.
      </p>
    </div>

    <div class="scrolly">
      <div class="steps">
        <CaseStudyStep
          num="01 / The context"
          screenId="s1"
          heading="A savings app for everyone — including a $0.05 deposit"
        >
          <p>
            Chumz lets people save toward personal or group goals through mobile
            money, with a default Quick Save goal for when they don't have a
            specific target in mind.
          </p>
          <br />
          <p>
            When I joined in January 2023 the product had traction — about
            30,000 users — and a long list of rough edges standing between it
            and the next order of magnitude.
          </p>
        </CaseStudyStep>

        <CaseStudyStep
          num="02 / My role"
          screenId="s2"
          heading="Owning the mobile experience end-to-end"
        >
          <p>
            I develop, design and prototype the mobile interfaces — and
            collaborate with other team members to{" "}
            <b>
              ship features that remind our users that Saving is a pillar of
              personal finance and enforce the habit through gamification</b
            >.
          </p>
          <br />
          <p>
            Two threads ran through that work:
            <b> remodelling core user flows</b> — tearing down and rebuilding the
            journeys people take most — and finding new ways to gamify saving.
          </p>
          <p class="todo">
            Mia Kwa Mia (100 for 100) — save KES 100 a day — was the first, born
            from asking whether daily earners could be nudged into saving small
            and often. The app now has 6 such challenges users return to
            regularly.
          </p>
        </CaseStudyStep>

        <CaseStudyStep
          num="03 / The unglamorous win"
          screenId="s3"
          heading="A dashboard that gave the support team superpowers"
        >
          <p>
            Growth creates tickets. I designed and built a <b
              >tailored customer-success dashboard</b
            > that pulled a scattered, multi-tool process into one screen — so the
            team could see, triage and resolve issues without jumping between five
            tools to do it.
          </p>
          <br />
          <p>
            Internal tools rarely make portfolios. They should: they're where
            you learn to build for your colleagues and make their work much
            easier.
          </p>
          <p class="todo">
            The dashboard resolves 300+ tickets a month. A one-tap "Get Help"
            button routes users straight to WhatsApp, so no one's left guessing
            about their savings.
          </p>
        </CaseStudyStep>

        <CaseStudyStep
          num="04 / The result"
          screenId="s4"
          heading="16.7× growth, and features that move real money"
        >
          <p>
            The product grew from <b>30,000 users to over 500,000</b> during my tenure,
            and the features I shipped meant people were saving more, and more often.
          </p>
          <div class="metric-row">
            <div class="metric"><b>500K+</b><span>users today</span></div>
            <div class="metric">
              <b>16.7×</b><span>growth since Jan '23</span>
            </div>
            <div class="metric"><b>$0.05</b><span>smallest deposit</span></div>
          </div>
          <blockquote class="testimonial">
            <p>
              "Working next to Favour, you notice he treats every screen like
              someone's real money is behind it — because it is. That discipline
              made the rest of us better, not just his own code."
            </p>
            <cite>— Antonio Maina, Engineer, Chumz</cite>
          </blockquote>
        </CaseStudyStep>
      </div>

      <PhoneMockup />
    </div>
  </div>
</section>

<style>
  .case {
    padding: 90px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .case-head {
    margin-bottom: 64px;
    max-width: 62ch;
  }
  h2 {
    margin-bottom: 18px;
  }
  .case-head p {
    color: var(--color-text-muted);
    font-size: var(--font-size-lg);
  }

  .scrolly {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 64px;
    align-items: start;
  }
  .steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Slotted step body content is authored here (not in case-study-step.astro),
     so these rules must live in this component's scope to apply to it. */
  .step p {
    color: var(--color-text-muted);
    font-size: var(--font-size-md-lg);
    max-width: 52ch;
    margin-bottom: 20px;
  }
  .step p b {
    color: var(--color-text);
    font-weight: 600;
  }
  .metric-row {
    display: flex;
    gap: 28px;
    margin-top: 18px;
    flex-wrap: wrap;
  }
  .metric b {
    display: block;
    font-size: var(--font-size-2xl);
    font-weight: 750;
    letter-spacing: -0.02em;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
    line-height: 1.1;
  }
  .metric span {
    font-family: var(--mono);
    font-size: var(--font-size-2xs);
    color: var(--color-text-muted);
  }
  .todo {
    font-family: var(--mono);
    font-size: var(--font-size-2xs);
    color: var(--color-accent-secondary);
    border: 1px dashed var(--color-accent-secondary-border);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    margin-top: 16px;
    max-width: 55ch;
  }
  .testimonial {
    margin-top: 20px;
    padding: 14px 18px;
    border-left: 3px solid var(--color-accent-secondary-border);
    max-width: 52ch;
  }
  .testimonial p {
    font-style: italic;
    margin-bottom: 8px !important;
  }
  .testimonial cite {
    display: block;
    font-style: normal;
    font-family: var(--mono);
    font-size: var(--font-size-2xs);
    color: var(--color-text-muted);
  }

  @media (max-width: 940px) {
    .scrolly {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const steps = document.querySelectorAll<HTMLElement>(".step");
  const screens = document.querySelectorAll<HTMLElement>(".screen");

  function activate(id: string, stepEl: Element) {
    steps.forEach((s) => s.classList.toggle("active", s === stepEl));
    screens.forEach((sc) => sc.classList.toggle("on", sc.id === id));
  }

  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const screenId = entry.target.getAttribute("data-screen");
          if (screenId) activate(screenId, entry.target);
        }
      });
    },
    { threshold: 0.55 },
  );
  steps.forEach((s) => obs.observe(s));
</script>
