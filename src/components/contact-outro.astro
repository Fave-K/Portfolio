---
import CopyEmailButton from "./copy-email-button.astro";
import { site } from "../data/site";
---

<section class="outro" id="contact">
  <div class="wrap">
    <p class="kicker">The next chapter could be yours</p>
    <h2>Building something people need to trust?</h2>
    <p>
      I reply within a day. Tell me what you're building and where the friction
      is.
    </p>
    <div class="outro-row">
      <a class="btn" href={`mailto:${site.email}`}>{site.email}</a>
      <CopyEmailButton email={site.email} variant="contact" />
      <!-- TODO: real GitHub/LinkedIn URLs -->
      <a class="btn ghost" href="#" rel="noopener">GitHub ↗</a>
      <a class="btn ghost" href="#" rel="noopener">LinkedIn ↗</a>
    </div>
  </div>
</section>

<style>
  .outro {
    padding: 110px 0 90px;
    text-align: center;
  }
  .outro .kicker {
    justify-content: center;
  }
  .outro h2 {
    font-size: clamp(34px, 5.6vw, 62px);
    max-width: 18ch;
    margin: 0 auto 22px;
  }
  .outro p {
    color: var(--color-text-muted);
    max-width: 55ch;
    margin: 0 auto 36px;
  }
  .outro-row {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
