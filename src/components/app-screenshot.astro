---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  width: number;
  height: number;
  widths?: number[];
  sizes?: string;
  priority?: boolean;
  format?: 'avif' | 'webp' | 'png' | 'jpeg';
  quality?: number | 'low' | 'mid' | 'high' | 'max';
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  widths = [320, 480, 640, 960],
  sizes = '(max-width: 640px) 100vw, 480px',
  priority = false,
  format = 'webp',
  quality = 80,
  class: className,
} = Astro.props;
---

<Image
  src={src}
  alt={alt}
  width={width}
  height={height}
  widths={widths}
  sizes={sizes}
  loading={priority ? 'eager' : 'lazy'}
  fetchpriority={priority ? 'high' : 'auto'}
  format={format}
  quality={quality}
  class={className}
/>
