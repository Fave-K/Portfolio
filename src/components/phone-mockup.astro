---
import PhoneScreenHome from './case-study/phone-screen-home.astro';
import PhoneScreenDeposit from './case-study/phone-screen-deposit.astro';
import PhoneScreenSupport from './case-study/phone-screen-support.astro';
import PhoneScreenGrowth from './case-study/phone-screen-growth.astro';
---

<div class="phone-wrap" aria-hidden="true">
  <div class="phone">
    <PhoneScreenHome />
    <PhoneScreenDeposit />
    <PhoneScreenSupport />
    <PhoneScreenGrowth />
  </div>
</div>

<style>
  .phone-wrap {
    position: sticky;
    top: 90px;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 940px) {
    .phone-wrap {
      position: relative;
      top: 0;
      order: -1;
      margin-bottom: 20px;
    }
  }
</style>

<style is:global>
  /* Shared "phone UI kit" — used across all four case-study/phone-screen-*.astro
     children. Kept global here (rather than duplicated per-screen) since Astro
     scopes styles per-component and these primitives are shared by all four. */
  .phone {
    width: 300px;
    height: 620px;
    border-radius: 44px;
    background: var(--color-shell-bg);
    border: 6px solid var(--color-shell-border);
    box-shadow:
      0 40px 90px -30px rgba(0, 0, 0, 0.7),
      inset 0 0 0 2px rgba(255, 255, 255, 0.04);
    position: relative;
    overflow: hidden;
  }
  .screen {
    position: absolute;
    inset: 0;
    padding: 0;
    opacity: 0;
    transition: opacity 0.45s;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .screen.on {
    opacity: 1;
  }
  .screenshot-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .screenshot-img--contain {
    object-fit: contain;
    object-position: center center;
  }

  @media (max-width: 940px) {
    .phone {
      width: 270px;
      height: 560px;
    }
    .screen {
      display: none;
    }
    .screen.on {
      display: flex;
      opacity: 1;
    }
  }
</style>
