---
---

<div class="screen" id="s4">
  <div class="app-top">
    <div class="hi">Growth <span>Jan 2023 → today</span></div>
    <div class="avatar"></div>
  </div>
  <div class="growth-svg">
    <svg
      viewBox="0 0 260 200"
      width="100%"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="User growth curve from 30,000 to over 500,000"
      focusable="false"
    >
      <defs>
        <linearGradient id="g" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" style="stop-color:var(--color-accent)" stop-opacity=".5"></stop>
          <stop offset="1" style="stop-color:var(--color-accent)" stop-opacity="0"></stop>
        </linearGradient>
      </defs>
      <path d="M10 180 C 70 175, 110 160, 150 120 S 220 30, 250 15 L 250 200 L 10 200 Z" fill="url(#g)"></path>
      <path
        d="M10 180 C 70 175, 110 160, 150 120 S 220 30, 250 15"
        fill="none"
        style="stroke:var(--color-accent)"
        stroke-width="3"
        stroke-linecap="round"></path>
      <circle cx="10" cy="180" r="4" style="fill:var(--color-accent-secondary)"></circle>
      <circle cx="250" cy="15" r="5" style="fill:var(--color-accent)"></circle>
      <text x="16" y="172" style="fill:var(--color-text-muted)" font-size="10" font-family="monospace">30K</text>
      <text x="196" y="14" style="fill:var(--color-accent)" font-size="11" font-family="monospace" font-weight="bold">500K+</text>
    </svg>
  </div>
  <div class="sheet">
    <div class="lbl">Assets under management</div>
    <div class="tickline"><span>trend</span><span style="color:var(--color-success)">▲ significant</span></div>
  </div>
</div>
