---
interface Props {
  num: string;
  screenId: string;
  heading: string;
}

const { num, screenId, heading } = Astro.props;
---

<div class="step" data-screen={screenId}>
  <p class="step-num">{num}</p>
  <h3>{heading}</h3>
  <slot />
</div>

<style>
  .step {
    min-height: 74vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px 0;
    opacity: 0.28;
    transition: opacity 0.4s;
  }
  .step.active {
    opacity: 1;
  }
  .step-num {
    font-family: var(--mono);
    font-size: var(--font-size-xs);
    color: var(--color-accent);
    margin-bottom: 14px;
  }
  h3 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-bottom: 14px;
  }

  @media (max-width: 940px) {
    .step {
      min-height: 0;
      padding: 34px 0;
      opacity: 1;
    }
  }
</style>
